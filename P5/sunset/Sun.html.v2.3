<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Biosphere - Interactive World</title>
    <script src="/P5/libraries/p5.min.js"></script>
    <script src="/P5/libraries/p5.sound.min.js"></script>
    <style>
        body { margin: 0; overflow: hidden; background: #0a0a0c; font-family: 'Poppins', sans-serif; display: flex; }
        canvas { display: block; }

        /* UI Sidebar */
        #control-panel {
            width: 280px;
            height: 100vh;
            background: rgba(15, 23, 42, 0.95);
            border-left: 1px solid rgba(56, 189, 248, 0.3);
            padding: 25px;
            box-sizing: border-box;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            gap: 25px;
            color: #f8fafc;
            backdrop-filter: blur(10px);
        }

        .control-group {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .control-label {
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #38bdf8;
        }

        .btn-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        .ui-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #94a3b8;
            padding: 10px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.8rem;
            transition: all 0.2s;
        }

        .ui-btn:hover { background: rgba(255, 255, 255, 0.1); color: #fff; }
        .ui-btn.active { 
            background: #38bdf8; 
            color: #0f172a; 
            border-color: #fff;
            box-shadow: 0 0 15px rgba(56, 189, 248, 0.4);
        }

        input[type="range"] {
            width: 100%;
            cursor: pointer;
        }

        /* Standard Hub Elements */
        #neural-pointer {
            position: fixed; width: 32px; height: 32px; pointer-events: none; z-index: 9999999;
            filter: drop-shadow(2px 0 0 #000) drop-shadow(-2px 0 0 #000) drop-shadow(0 2px 0 #000) drop-shadow(0 -2px 0 #000);
        }
        #neural-pointer::before {
            content: ''; position: absolute; inset: 0; 
            clip-path: polygon(0% 0%, 100% 70%, 40% 70%, 40% 100%);
            transition: background 0.3s ease;
        }
        #neural-pointer.day-mode::before { background: #ffffff; }
        #neural-pointer.night-mode::before { background: #000000; filter: drop-shadow(0 0 5px #fff); }

        .global-hub-btn {
            position: fixed; bottom: 25px; left: 25px; z-index: 2000;
            background: linear-gradient(135deg, #00f2ff 0%, #0077ff 100%);
            color: white !important; text-decoration: none !important;
            padding: 14px 28px; border-radius: 50px; font-weight: 800;
            box-shadow: 0 0 20px rgba(0, 242, 255, 0.4);
        }

        *, html, body { cursor: none !important; }
    </style>
</head>
<body>

    <main style="flex-grow: 1; position: relative;">
        <div id="p5-container"></div>
    </main>

    <aside id="control-panel">
        <h2 style="font-size: 1.2rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px; margin: 0;">BIOSPHERE_CTRL</h2>
        
        <div class="control-group">
            <span class="control-label">Time of Day</span>
            <input type="range" id="time-slider" min="0" max="23" value="12" oninput="updateTime(this.value)">
            <div style="display: flex; justify-content: space-between; font-size: 0.7rem; color: #475569;">
                <span>00:00</span>
                <span>12:00</span>
                <span>23:59</span>
            </div>
        </div>

        <div class="control-group">
            <span class="control-label">Season</span>
            <div class="btn-grid">
                <button class="ui-btn active" id="btn-SPRING" onclick="setSeason('SPRING')">Spring</button>
                <button class="ui-btn" id="btn-SUMMER" onclick="setSeason('SUMMER')">Summer</button>
                <button class="ui-btn" id="btn-AUTUMN" onclick="setSeason('AUTUMN')">Autumn</button>
                <button class="ui-btn" id="btn-WINTER" onclick="setSeason('WINTER')">Winter</button>
            </div>
        </div>

        <div class="control-group">
            <span class="control-label">Weather Matrix</span>
            <div class="btn-grid">
                <button class="ui-btn active" id="btn-CLEAR" onclick="setWeather('CLEAR')">Clear</button>
                <button class="ui-btn" id="btn-RAIN" onclick="setWeather('RAIN')">Rain</button>
                <button class="ui-btn" id="btn-SNOW" onclick="setWeather('SNOW')">Snow</button>
                <button class="ui-btn" id="btn-STORM" onclick="setWeather('STORM')">Storm</button>
            </div>
        </div>

        <div class="control-group" style="margin-top: auto;">
            <p style="font-size: 0.7rem; color: #475569; line-height: 1.4;">GLOBAL BIOSPHERE v3.0<br>Real-time Environmental Simulation</p>
        </div>
    </aside>

    <a href="../../index.html" class="global-hub-btn">Back to the Hub</a>
    <div id="neural-pointer"></div>

    <script src="Sun.js"></script>
    <script>
        // UI Interaction Glue
        function updateTime(v) { window.worldTimeOfDay = parseInt(v); }
        function setSeason(s) { 
            window.currentSeason = s; 
            document.querySelectorAll('.ui-btn[id^="btn-S"]').forEach(b => b.classList.remove('active'));
            document.getElementById('btn-'+s).classList.add('active');
        }
        function setWeather(w) { 
            window.currentWeather = w; 
            document.querySelectorAll('.ui-btn[id^="btn-"]').forEach(b => {
                if(!b.id.includes('SPRING') && !b.id.includes('SUMMER') && !b.id.includes('AUTUMN') && !b.id.includes('WINTER'))
                    b.classList.remove('active');
            });
            document.getElementById('btn-'+w).classList.add('active');
        }

        // Standard Pointer
        (function() {
            const pointer = document.getElementById('neural-pointer');
            let hue = 0;
            function tick() {
                const hour = new Date().getHours();
                const isDay = hour >= 6 && hour < 18;
                if (pointer) {
                    pointer.classList.toggle('day-mode', isDay);
                    pointer.classList.toggle('night-mode', !isDay);
                    hue = (hue + 2) % 360;
                    pointer.style.setProperty('--rainbow-glow', `hsl(${hue}, 100%, ${isDay?85:60}%)`);
                }
                requestAnimationFrame(tick);
            }
            window.addEventListener('mousemove', (e) => {
                if (pointer) { pointer.style.left = e.clientX + 'px'; pointer.style.top = e.clientY + 'px'; }
            });
            tick();
        })();
    </script>
</body>
</html>
